# Docker / production data directory (default: ./data locally, /data in container)
# LOOPER_DATA_DIR=/data
# LOOPER_PORT=3001

# Pilot unlock code (default: 333333) — share with test group
# GATE_CODE=333333

# Skip unlock gate (public demo only — not for real pilot)
# DEMO_PUBLIC=1
# NEXT_PUBLIC_DEMO_PUBLIC=1

# Codegen agent (NORTHPOLE builder=agent)
# BUILD_AGENT_URL=http://localhost:3000/api/build/agent-stub
# BUILD_AGENT_TOKEN=